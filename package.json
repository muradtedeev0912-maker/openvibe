{
  "name": "openvibe",
  "version": "0.1.0",
  "description": "Open-source agentic coding environment. Bring your own AI model.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "mt-studio <mt-studio@bk.ru>",
  "repository": {
    "type": "git",
    "url": "https://github.com/mttscode/openvibe"
  },
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.node.json --watch",
    "build:renderer": "vite build",
    "build:node": "tsc -p tsconfig.node.json",
    "copy:preload": "node -e \"import('node:fs').then(({copyFileSync,mkdirSync})=>{mkdirSync('dist/electron',{recursive:true});copyFileSync('electron/preload.cjs','dist/electron/preload.cjs')})\"",
    "build": "npm run build:renderer && npm run build:node && npm run copy:preload",
    "start": "electron .",
    "dev": "node scripts/dev.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "coding",
    "claude-code",
    "openai",
    "electron",
    "desktop"
  ],
  "build": {
    "appId": "com.openvibe.app",
    "productName": "openvibe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
